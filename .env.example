# Frontend (local dev)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=TeaFlow BobaPOS

# Vercel production — chọn 1 trong 2 cách:

# Cách 1 (khuyên dùng): proxy qua cùng domain, tránh CORS
# API_PROXY_TARGET=https://<render-domain>/api

# Cách 2: gọi thẳng backend Render
# NEXT_PUBLIC_API_BASE_URL=https://<render-domain>/api
